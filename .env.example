# Environment configuration for local development
# Copy this file to .env.local and fill in the required values.

# Gemini API key for embeddings and chat generation
GEMINI_API_KEY=your_gemini_api_key_here

# Vector database selection: lancedb or supabase
VECTOR_DB=lancedb

# Supabase settings (only required when VECTOR_DB=supabase)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
